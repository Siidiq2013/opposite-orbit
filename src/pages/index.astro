---
// src/pages/index.astro
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout pageTitle="Adv. Sadiq Adan Ali — Legal Professional & Data Practitioner" activePage="home">
  <style is:inline>
    /* Homepage Specific Page Styles */
    .hero { min-height: 100vh; background: var(--navy); display: flex; align-items: center; padding: 7rem var(--pad) 5rem; position: relative; overflow: hidden; }
    .hero::before { content: '⚖'; position: absolute; right: -2rem; bottom: -3rem; font-size: clamp(16rem, 35vw, 28rem); line-height: 1; color: rgba(181,137,42,0.07); pointer-events: none; user-select: none; }
    .hero-inner { max-width: var(--max); margin: 0 auto; width: 100%; position: relative; }
    .hero-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.25rem; }
    .hero h1 { font-family: var(--serif); font-size: clamp(2.6rem, 7vw, 5rem); font-weight: 700; line-height: 1.08; color: #fff; margin-bottom: 1rem; }
    .hero h1 em { font-style: italic; color: var(--gold-lt); }
    .hero-tagline { font-family: var(--serif); font-size: clamp(1rem, 2.5vw, 1.3rem); font-style: italic; color: rgba(255,255,255,0.65); margin-bottom: 2rem; max-width: 540px; }
    .hero-meta { display: flex; flex-wrap: wrap; gap: 0.75rem 1.5rem; margin-bottom: 2.5rem; }
    .hero-meta a, .hero-meta span { font-size: 0.82rem; color: rgba(255,255,255,0.6); text-decoration: none; display: flex; align-items: center; gap: 0.4rem; transition: color 0.2s; }
    .hero-meta a:hover { color: var(--gold-lt); }
    .hero-meta svg { width: 14px; height: 14px; flex-shrink: 0; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; }
    
    .stats { background: var(--gold); padding: 1.5rem var(--pad); }
    .stats-inner { max-width: var(--max); margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; text-align: center; }
    .stat-num { display: block; font-family: var(--serif); font-size: 2.2rem; font-weight: 700; color: var(--navy); line-height: 1; }
    .stat-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(13,31,60,0.7); }
    
    .about-preview { background: #fff; padding: 5rem var(--pad); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
    .about-text p { color: var(--mid); margin-bottom: 1rem; font-size: 0.97rem; }
    .about-quote { background: var(--navy); padding: 2rem 2rem 2rem 2.5rem; border-left: 4px solid var(--gold); }
    .about-quote blockquote { font-family: var(--serif); font-size: 1.2rem; font-style: italic; color: rgba(255,255,255,0.9); line-height: 1.55; }
    .about-quote cite { display: block; margin-top: 1rem; font-size: 0.78rem; font-style: normal; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold); }
    
    .practice-preview { background: var(--parchment); padding: 5rem var(--pad); }
    .practice-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
    .practice-card { background: #fff; border: 1px solid var(--mist); padding: 1.75rem; position: relative; transition: border-color 0.2s, transform 0.2s; }
    .practice-card:hover { border-color: var(--gold); transform: translateY(-3px); }
    .practice-card::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.25s; }
    .practice-card:hover::after { transform: scaleX(1); }
    .practice-rate { font-family: var(--serif); font-size: 2rem; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 0.25rem; }
    .practice-title { font-weight: 600; font-size: 0.95rem; color: var(--navy); margin-bottom: 0.5rem; }
    .practice-cases { font-size: 0.8rem; color: var(--mid); }
    .section-cta { margin-top: 2.5rem; }
    @media (max-width: 680px) { .about-grid { grid-template-columns: 1fr; } }
  </style>

  <header class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">Advocate · Legal Consultant · Data Practitioner[cite: 4]</p>
      <h1>Adv. <em>Sadiq</em><br>Adan Ali[cite: 4]</h1>
      <p class="hero-tagline">Committed to Justice, Research,<br>Data-Driven Solutions &amp; Sustainable Peace.[cite: 4]</p>
      <div class="hero-meta">
        <span>
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Mogadishu, Somalia[cite: 4]
        </span>
        <a href="mailto:avv.sadiq@mail.com">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          avv.sadiq@mail.com[cite: 4]
        </a>
        <a href="tel:+252613741177">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          +252 613 741 177[cite: 4]
        </a>
      </div>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Get in Touch
        </a>
        <a href="/practice" class="btn-outline">View Practice Areas[cite: 4]</a>
      </div>
    </div>
  </header>

  <div class="stats">
    <div class="stats-inner">
      <div data-fade><span class="stat-num">1,450+</span><span class="stat-label">Cases Handled[cite: 4]</span></div>
      <div data-fade><span class="stat-num">89%</span><span class="stat-label">Civil Success Rate[cite: 4]</span></div>
      <div data-fade><span class="stat-num">271</span><span class="stat-label">Disputes Resolved[cite: 4]</span></div>
      <div data-fade><span class="stat-num">10+</span><span class="stat-label">Research Publications[cite: 4]</span></div>
    </div>
  </div>

  <section class="about-preview">
    <div class="section-inner">
      <p class="section-label">Who I Am[cite: 4]</p>
      <h2 class="section-title">A Legal Professional<br>Grounded in Evidence[cite: 4]</h2>
      <div class="rule"></div>
      <div class="about-grid">
        <div class="about-text" data-fade>
          <p>Adv. Sadiq Adan Ali is a dedicated legal professional and data practitioner with extensive experience in litigation, legal advisory, corporate and commercial law, conflict resolution, and social justice.[cite: 4]</p>
          <p>With over 1,450 cases handled and a strong success record, he combines legal expertise with data analysis and research capabilities to deliver evidence-based solutions for individuals, businesses, organizations, and communities.[cite: 4]</p>
          <p>He is committed to promoting access to justice, child protection, gender-based violence prevention, women's empowerment, and sustainable peacebuilding throughout Somalia.[cite: 4]</p>
          <div class="section-cta"><a href="/about" class="btn-primary">Read Full Profile[cite: 4]</a></div>
        </div>
        <div data-fade>
          <div class="about-quote">
            <blockquote>"Committed to Justice, Research, Data-Driven Solutions, Sustainable Justice, and Sustainable Peace."[cite: 4]</blockquote>
            <cite>— Adv. Sadiq Adan Ali[cite: 4]</cite>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="practice-preview">
    <div class="section-inner">
      <p class="section-label">Expertise[cite: 4]</p>
      <h2 class="section-title">Practice Areas[cite: 4]</h2>
      <div class="rule"></div>
      <div class="practice-grid">
        <div class="practice-card" data-fade>
          <div class="practice-rate">89%[cite: 4]</div>
          <div class="practice-title">Civil Litigation[cite: 4]</div>
          <p class="practice-cases">500+ cases handled across Somalia's federal courts.[cite: 4]</p>
        </div>
        <div class="practice-card" data-fade>
          <div class="practice-rate">86%[cite: 4]</div>
          <div class="practice-title">Criminal Litigation[cite: 4]</div>
          <p class="practice-cases">350+ criminal cases with strong courtroom advocacy.[cite: 4]</p>
        </div>
        <div class="practice-card" data-fade>
          <div class="practice-rate">90%[cite: 4]</div>
          <div class="practice-title">Business &amp; Property[cite: 4]</div>
          <p class="practice-cases">600+ corporate, commercial, and property matters.[cite: 4]</p>
        </div>
        <div class="practice-card" data-fade>
          <div class="practice-rate">271[cite: 4]</div>
          <div class="practice-title">Dispute Resolution[cite: 4]</div>
          <p class="practice-cases">Resolved through negotiation, mediation, and reconciliation.[cite: 4]</p>
        </div>
      </div>
      <div class="section-cta"><a href="/practice" class="btn-primary">All Practice Areas[cite: 4]</a></div>
    </div>
  </section>
</LegalLayout>