---
import LegalLayout from '../layouts/Legallayout.astro';
---

<LegalLayout pageTitle="Skills" activePage="skills">
  <style is:inline>
    .skills-section { background: var(--parchment); padding: 5rem var(--pad); }
    .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; }
    .skill-group { background: #fff; border: 1px solid var(--mist); padding: 1.75rem; }
    .skill-group-title { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--rule); }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tag { font-size: 0.78rem; padding: 0.35rem 0.75rem; background: var(--parchment); border: 1px solid var(--mist); color: var(--mid); transition: border-color 0.2s, color 0.2s; cursor: default; }
    .tag:hover { border-color: var(--gold); color: var(--navy); }
    
    .certs-section { background: #fff; padding: 5rem var(--pad); }
    .cert-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; }
    .cert-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 1.25rem; border-left: 3px solid var(--gold); background: var(--parchment); transition: background 0.2s; }
    .cert-item:hover { background: var(--mist); }
    .cert-icon { color: var(--gold); flex-shrink: 0; margin-top: 0.1rem; }
    .cert-name { font-size: 0.88rem; font-weight: 600; color: var(--navy); line-height: 1.35; }
    .cert-issuer { font-size: 0.75rem; color: var(--mid); margin-top: 0.2rem; }
  </style>

  <header class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">Capabilities</p>
      <h1>Technical &amp;<br>Professional <em>Skills</em></h1>
      <p class="page-hero-sub">A broad range of legal, data, and technology competencies developed across practice and research[cite: 10].</p>
    </div>
  </header>

  <section class="skills-section">
    <div class="section-inner">
      <p class="section-label">Capabilities</p>
      <h2 class="section-title">Core Competencies</h2>
      <div class="rule"></div>
      <div class="skills-grid">
        <div class="skill-group" data-fade>
          <p class="skill-group-title">Legal Skills</p>
          <div class="skill-tags">
            <span class="tag">Litigation &amp; Advocacy[cite: 10]</span>
            <span class="tag">Legal Research[cite: 10]</span>
            <span class="tag">Contract Drafting[cite: 10]</span>
            <span class="tag">Case Management[cite: 10]</span>
            <span class="tag">Client Representation[cite: 10]</span>
            <span class="tag">Mediation[cite: 10]</span>
            <span class="tag">Negotiation[cite: 10]</span>
          </div>
        </div>
        <div class="skill-group" data-fade>
          <p class="skill-group-title">Data &amp; Research</p>
          <div class="skill-tags">
            <span class="tag">Data Analysis[cite: 10]</span>
            <span class="tag">Data Management[cite: 10]</span>
            <span class="tag">Market Research[cite: 10]</span>
            <span class="tag">Market Analysis[cite: 10]</span>
            <span class="tag">Report Writing[cite: 10]</span>
            <span class="tag">Data Visualization[cite: 10]</span>
          </div>
        </div>
        <div class="skill-group" data-fade>
          <p class="skill-group-title">Information Technology</p>
          <div class="skill-tags">
            <span class="tag">Website Design[cite: 10]</span>
            <span class="tag">Social Media[cite: 10]</span>
            <span class="tag">Digital Marketing[cite: 10]</span>
            <span class="tag">Content Development[cite: 10]</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="certs-section">
    <div class="section-inner">
      <p class="section-label">Professional Development</p>
      <h2 class="section-title">Certifications</h2>
      <div class="rule"></div>
      <div class="cert-list" data-fade>
        <div class="cert-item">
          <svg class="cert-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          <div>
            <div class="cert-name">Data Science Professional Certificate[cite: 10]</div>
            <div class="cert-issuer">IBM · Coursera[cite: 10]</div>
          </div>
        </div>
        <div class="cert-item">
          <svg class="cert-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          <div>
            <div class="cert-name">Data Analyst Professional Certificate[cite: 10]</div>
            <div class="cert-issuer">IBM · Coursera[cite: 10]</div>
          </div>
        </div>
        <div class="cert-item">
          <svg class="cert-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          <div>
            <div class="cert-name">Google Data Analytics Professional Certificate[cite: 10]</div>
            <div class="cert-issuer">Google · Coursera[cite: 10]</div>
          </div>
        </div>
        <div class="cert-item">
          <svg class="cert-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          <div>
            <div class="cert-name">Google Digital Marketing &amp; E-Commerce Certificate[cite: 10]</div>
            <div class="cert-issuer">Google · Coursera[cite: 10]</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</LegalLayout>