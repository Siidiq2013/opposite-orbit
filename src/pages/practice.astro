---
import LegalLayout from '../layouts/Legallayout.astro';
---

<LegalLayout pageTitle="Practice Areas" activePage="practice">
  <style is:inline>
    .practice-section { padding: 5rem var(--pad); background: var(--parchment); }
    .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }
    .pcard { background: #fff; border: 1px solid var(--mist); padding: 2rem; position: relative; transition: border-color 0.2s, transform 0.2s; }
    .pcard:hover { border-color: var(--gold); transform: translateY(-3px); }
    .pcard::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.25s; }
    .pcard:hover::after { transform: scaleX(1); }
    .pcard-rate { font-family: var(--serif); font-size: 2.4rem; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 0.5rem; }
    .pcard-title { font-weight: 600; font-size: 1rem; color: var(--navy); margin-bottom: 0.5rem; }
    .pcard-desc { font-size: 0.875rem; color: var(--mid); line-height: 1.6; }
    .pcard-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 1rem; }
    .ptag { font-size: 0.72rem; padding: 0.2rem 0.6rem; border: 1px solid var(--mist); color: var(--mid); }
    
    .adr-section { background: var(--navy); padding: 5rem var(--pad); }
    .adr-section .section-title { color: #fff; }
    .adr-section .section-label { color: var(--gold-lt); }
    .adr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
    .adr-stat { font-family: var(--serif); font-size: 4rem; font-weight: 700; color: var(--gold); line-height: 1; }
    .adr-desc { color: rgba(255,255,255,0.65); font-size: 0.95rem; line-height: 1.7; }
    .adr-methods { margin-top: 1.5rem; display: grid; gap: 0.6rem; }
    .adr-method { display: flex; align-items: center; gap: 0.75rem; color: rgba(255,255,255,0.7); font-size: 0.88rem; }
    .adr-method::before { content: ''; display: block; width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }
    @media (max-width: 680px) { .adr-grid { grid-template-columns: 1fr; } }
  </style>

  <header class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">Expertise</p>
      <h1>Practice <em>Areas</em></h1>
      <p class="page-hero-sub">Comprehensive legal representation across civil, criminal, corporate, and social justice matters[cite: 9].</p>
    </div>
  </header>

  <section class="practice-section">
    <div class="section-inner">
      <p class="section-label">Core Practice</p>
      <h2 class="section-title">Legal Representation</h2>
      <div class="rule"></div>
      <div class="cards-grid">
        <div class="pcard" data-fade>
          <div class="pcard-rate">89%</div>
          <div class="pcard-title">Civil Litigation</div>
          <p class="pcard-desc">Representing individuals and institutions in civil disputes across Somalia's federal and state courts. Covering property disputes, contract breaches, civil rights, and family law[cite: 9].</p>
          <div class="pcard-tags">
            <span class="ptag">Property Law</span><span class="ptag">Contract Disputes</span><span class="ptag">Family Law</span><span class="ptag">500+ Cases</span>
          </div>
        </div>
        <div class="pcard" data-fade>
          <div class="pcard-rate">86%</div>
          <div class="pcard-title">Criminal Litigation</div>
          <p class="pcard-desc">Skilled courtroom advocacy in criminal proceedings before the Supreme Courts of Somalia, Puntland, and Galmudug — protecting the rights of the accused with vigorous defence strategies[cite: 9].</p>
          <div class="pcard-tags">
            <span class="ptag">Criminal Defence</span><span class="ptag">Appeals</span><span class="ptag">Human Rights</span><span class="ptag">350+ Cases</span>
          </div>
        </div>
        <div class="pcard" data-fade>
          <div class="pcard-rate">90%</div>
          <div class="pcard-title">Business &amp; Property Law</div>
          <p class="pcard-desc">End-to-end corporate and commercial legal services: business formation, contract drafting, commercial disputes, real estate transactions, and regulatory compliance[cite: 9].</p>
          <div class="pcard-tags">
            <span class="ptag">Corporate Law</span><span class="ptag">Real Estate</span><span class="ptag">Contracts</span><span class="ptag">600+ Matters</span>
          </div>
        </div>
        <div class="pcard" data-fade>
          <div class="pcard-rate" style="font-size:1.8rem;">Human Rights<br>&amp; Social Justice</div>
          <div class="pcard-title" style="margin-top:0.5rem;">Advocacy &amp; Protection</div>
          <p class="pcard-desc">Championing child protection, GBV prevention, women's empowerment, and access to justice for vulnerable populations through both litigation and legal aid programmes[cite: 9].</p>
          <div class="pcard-tags">
            <span class="ptag">GBV Prevention</span><span class="ptag">Child Protection</span><span class="ptag">Legal Aid</span><span class="ptag">Peacebuilding</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="adr-section">
    <div class="section-inner">
      <div class="adr-grid">
        <div data-fade>
          <p class="section-label" style="color:var(--gold-lt)">Alternative Dispute Resolution</p>
          <h2 class="section-title" style="color:#fff;">Resolving Conflicts<br>Beyond the Courtroom</h2>
          <div class="rule" style="background:rgba(181,137,42,0.5)"></div>
          <p class="adr-desc">When parties are best served outside formal litigation, Adv. Sadiq provides structured, impartial dispute resolution using mediation, negotiation, and traditional reconciliation processes — preserving relationships while securing just outcomes[cite: 9].</p>
          <div class="adr-methods">
            <div class="adr-method">Negotiation &amp; Settlement</div>
            <div class="adr-method">Mediation</div>
            <div class="adr-method">Reconciliation &amp; Peacebuilding</div>
            <div class="adr-method">Community-Based Resolution</div>
          </div>
        </div>
        <div data-fade style="text-align:center;">
          <div class="adr-stat">271</div>
          <p style="font-family:var(--serif);font-size:1.1rem;font-style:italic;color:rgba(255,255,255,0.5);margin-top:0.5rem;">Disputes successfully resolved[cite: 9]</p>
          <div style="margin-top:2rem;"><a href="/contact" class="btn-primary">Discuss Your Case</a></div>
        </div>
      </div>
    </div>
  </section>
</LegalLayout>